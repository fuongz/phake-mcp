# Cloudflare Workers MCP Server with Google OAuth

# KV Namespace - create via: wrangler kv namespace create TOKENS
RS_TOKENS_ENC_KEY=

# OAuth client (your MCP app)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Google OAuth provider
PROVIDER_CLIENT_ID=
PROVIDER_CLIENT_SECRET=

# OAuth configuration (already set in wrangler.jsonc vars, can override here)
# OAUTH_SCOPES=openid email profile
# OAUTH_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token