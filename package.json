{
	"name": "@phake/mcp",
	"version": "0.2.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/fuongz/phake-mcp"
	},
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"create-phake-mcp": "./bin/create-mcp"
	},
	"files": [
		"dist",
		"bin",
		"templates"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./runtime/node": {
			"types": "./dist/runtime/node/index.d.ts",
			"default": "./dist/runtime/node/index.js"
		},
		"./runtime/worker": {
			"types": "./dist/runtime/worker/index.d.ts",
			"default": "./dist/runtime/worker/index.js"
		}
	},
	"scripts": {
		"build": "bun build src/index.ts src/runtime/worker/index.ts --outdir dist --target browser --splitting --packages external && bun build src/runtime/node/index.ts --outdir dist/runtime/node --target bun && tsc -p tsconfig.build.json && bun run build:create",
		"build:create": "bun build src/create-mcp/index.ts --outfile=./bin/create-mcp --target=node --format=esm --banner='#!'",
		"test": "bun test src/__tests__",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"version:major": "bun scripts/version.ts major",
		"version:minor": "bun scripts/version.ts minor",
		"version:patch": "bun scripts/version.ts patch"
	},
	"dependencies": {
		"@bluwy/giget-core": "^0.1.6",
		"@inquirer/confirm": "^5.1.8",
		"@inquirer/input": "^4.1.8",
		"@inquirer/select": "^4.1.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"commander": "^13.1.0",
		"itty-router": "^5.0.23",
		"jose": "^6.2.2",
		"nanospinner": "^1.2.2",
		"oauth4webapi": "^3.8.5",
		"picocolors": "^1.1.1",
		"zod": "^4.3.6"
	},
	"optionalDependencies": {
		"@hono/node-server": "^1.19.12",
		"better-sqlite3": "^12.8.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.9"
	},
	"peerDependencies": {
		"@hono/node-server": ">=1.0.0",
		"better-sqlite3": ">=9.0.0",
		"hono": ">=4.0.0"
	},
	"peerDependenciesMeta": {
		"@hono/node-server": {
			"optional": true
		},
		"better-sqlite3": {
			"optional": true
		},
		"hono": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.13.11",
		"bun-types": "^1.3.11",
		"typescript": "^6.0.2"
	}
}
