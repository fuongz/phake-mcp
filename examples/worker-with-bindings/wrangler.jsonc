{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "prod-hiip-wiki",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-06",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": true,
	"kv_namespaces": [
		{
			"binding": "TOKENS",
			"id": "<your-kv-namespace-id>"
		},
		{
			"binding": "TEST",
			"id": "test"
		}
	],
	"vars": {
		"AUTH_STRATEGY": "google",
		"OAUTH_SCOPES": "openid email profile",
		"AUTH_ENABLED": "true"
	}
}
